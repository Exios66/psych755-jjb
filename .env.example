# Choose provider: ollama | openrouter
CA_LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Optional OpenRouter headers
OPENROUTER_HTTP_REFERER=https://github.com/Exios66/psych755-jjb
OPENROUTER_APP_TITLE=psych755-ca-personas
